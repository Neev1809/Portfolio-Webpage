body {
    font-family: Arial;
    background-color: #f4f4f4;
    margin: 0;
}

header {
    background-color: #333;
    color: white;
    text-align: center;
    padding: 20px;
}

section {
    background: white;
    margin: 20px;
    padding: 15px;
    border-radius: 8px;
}

h2 {
    color: #333;
}

a {
    color: blue;
    text-decoration: none;
}

a:hover {
    color: red;
}
